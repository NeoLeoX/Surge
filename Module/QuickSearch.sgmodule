#!name=快捷搜索
#!desc=为Safari提供快速切换搜索引擎的能力，在插件列表中点击此插件上的链接查看使用方法。
#!category=Ciel
[URL Rewrite]
^https:\/\/duckduckgo\.com\/\?.*[?&]q=bd(?:\+|%20|%2B)?([^&]*) https://www.baidu.com/s?wd=$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=bdimg(?:\+|%20|%2B)?([^&]*) https://image.baidu.com/search/index?tn=baiduimage&word=$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=gimg(?:\+|%20|%2B)?([^&]*) https://www.google.com/search?tbm=isch&q=$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=b(?:\+|%20|%2B)?([^&]*) https://www.bing.com/search?q=$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=wk(?:\+|%20|%2B)?([^&]*) https://zh.wikipedia.org/wiki/$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=qm(?:\+|%20|%2B)?([^&]*) https://www.qimai.cn/search/index/country/cn/search/$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=gh(?:\+|%20|%2B)?([^&]*) https://github.com/search?q=$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=db(?:\+|%20|%2B)?([^&]*) https://search.douban.com/movie/subject_search?search_text=$1 307
^https:\/\/duckduckgo\.com\/\?.*[?&]q=([^&]+) https://www.google.com/search?q=$1 307
[MITM]
hostname = %APPEND% duckduckgo.com
